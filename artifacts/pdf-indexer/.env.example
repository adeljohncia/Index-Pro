# Backend OCR Service Configuration
# Set these environment variables to configure the OCR backend

# Enable backend OCR service (default: true)
VITE_BACKEND_OCR_ENABLED=true

# Backend service URL (default: http://localhost:8000)
VITE_BACKEND_URL=http://localhost:8000

# Backend request timeout in milliseconds (default: 60000)
VITE_BACKEND_TIMEOUT=60000

# Default OCR quality: 'fast', 'balanced', or 'maximum' (default: balanced)
VITE_DEFAULT_OCR_QUALITY=balanced

# Enable multi-language detection (default: true)
VITE_ENABLE_MULTILANG=true

# Enable layout analysis (columns, structure) (default: true)
VITE_ENABLE_LAYOUT_ANALYSIS=true

# Enable table detection (default: true)
VITE_ENABLE_TABLE_DETECTION=true

# Enable AI spell correction (default: true)
VITE_ENABLE_SPELL_CORRECTION=true

# Example for production with remote backend:
# VITE_BACKEND_URL=https://ocr-api.example.com
# VITE_BACKEND_OCR_ENABLED=true
