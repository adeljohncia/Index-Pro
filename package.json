{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "dev": "corepack pnpm --filter @workspace/pdf-indexer run dev",
    "serve": "corepack pnpm --filter @workspace/pdf-indexer run serve",
    "build": "corepack pnpm run typecheck && corepack pnpm -r --if-present run build",
    "build:pdf-indexer": "corepack pnpm --filter @workspace/pdf-indexer run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "corepack pnpm run typecheck:libs && corepack pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "typecheck:pdf-indexer": "corepack pnpm --filter @workspace/pdf-indexer run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
